# TailTopia 后端本地环境变量样例。复制为 .env 后按需修改。真实凭证绝不入库（.env 已在 .gitignore）。
# 本 Story（1.1）只需 DB / Redis；OAuth / Gemini / 腾讯 IM / 阿里云 OSS 等凭证后续 Story 才需要。

# --- 数据库 (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petgo
DB_USER=petgo
DB_PASSWORD=petgo

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 应用 ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- auth (Story 1.3) ---
# 自签 JWT HMAC 密钥（≥32 字节）。生产必填强随机值。
JWT_SECRET=dev-only-insecure-jwt-secret-please-change-0123456789
# JWT_ISSUER=petgo
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_DAYS=30
# Google OAuth client id（L2 真实登录需要；L0/L1 用 stub verifier 免凭证）。
GOOGLE_OAUTH_CLIENT_ID=

# --- 媒体基建 (Story 2.1) 阿里云 OSS 雅加达双桶 + STS ---
# 真实凭证仅运行环境注入，绝不入库；留空时 L0 单测用 mock，不打真实 OSS/STS。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-5.aliyuncs.com
OSS_REGION=ap-southeast-5
OSS_PUBLIC_BUCKET=
OSS_PRIVATE_BUCKET=
OSS_CDN_BASE_URL=
STS_ROLE_ARN=
STS_ENDPOINT=sts.ap-southeast-5.aliyuncs.com
# STS_DURATION_SECONDS=900
# SIGNED_URL_TTL_SECONDS=300

# --- AI 智能分诊 (Story 4.1) Gemini Developer API ---
# mode=stub（默认）走打桩客户端，无凭证即可启动并验状态机（L0/L1）；
# mode=live 才打真实 gemini-2.5-flash（L2，需真实 key + 私密桶签名 URL）。key 绝不入库 / 不落日志。
GEMINI_MODE=stub
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIMEOUT_SECONDS=10

# --- 腾讯 IM 实时会话 (Story 5.5) ---
# mode=stub（默认）走打桩 IM 客户端：本地生成会话 id + 占位 UserSig，无凭证即可验状态机/接单 CAS（L0/L1）。
# mode=live 才接真实腾讯 IM（L2，需真机 + 真实 SDKAppID/SecretKey + SDK 直连）。SecretKey 绝不下发客户端 / 绝不入日志。
IM_MODE=stub
TENCENT_IM_SDK_APP_ID=
TENCENT_IM_SECRET_KEY=
# IM_USERSIG_TTL_SECONDS=86400
# 腾讯 IM 服务端回调签名校验用（/im/callback，内网/白名单 + 签名）。
TENCENT_IM_CALLBACK_TOKEN=
# live REST 域名（数据中心德国/欧洲，与后端同区）+ 管理员 IM 标识（REST 鉴权身份，需控制台配为 App 管理员；不计 MAU）。
# IM_REST_BASE_URL=https://adminapiger.im.qcloud.com
# IM_ADMIN_IDENTIFIER=administrator
