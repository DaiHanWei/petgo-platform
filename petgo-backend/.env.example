# PetGo 后端本地环境变量样例。复制为 .env 后按需修改。真实凭证绝不入库（.env 已在 .gitignore）。
# 本 Story（1.1）只需 DB / Redis；OAuth / Gemini / 腾讯 IM / 阿里云 OSS 等凭证后续 Story 才需要。

# --- 数据库 (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petgo
DB_USER=petgo
DB_PASSWORD=petgo

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 应用 ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- 后续 Story 才需要（占位，勿填真实值入库）---
# GOOGLE_OAUTH_CLIENT_ID=
# GEMINI_API_KEY=
# TENCENT_IM_APP_ID=
# ALIYUN_OSS_ACCESS_KEY_ID=
