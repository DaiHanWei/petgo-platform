# TailTopia 后端本地环境变量样例。复制为 .env 后按需修改。真实凭证绝不入库（.env 已在 .gitignore）。
# 本 Story（1.1）只需 DB / Redis；OAuth / Gemini / 腾讯 IM / 阿里云 OSS 等凭证后续 Story 才需要。

# --- 数据库 (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petgo
DB_USER=petgo
DB_PASSWORD=petgo

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 应用 ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- auth (Story 1.3) ---
# 自签 JWT HMAC 密钥（≥32 字节）。生产必填强随机值。
JWT_SECRET=dev-only-insecure-jwt-secret-please-change-0123456789
# JWT_ISSUER=petgo
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_DAYS=30
# Google OAuth client id（L2 真实登录需要；L0/L1 用 stub verifier 免凭证）。
GOOGLE_OAUTH_CLIENT_ID=
# Apple Sign-In client id（aud 校验，通常 = iOS bundle id；FR-44，L2 真实登录需要；L0/L1 用 stub verifier 免凭证）。
APPLE_CLIENT_ID=

# --- 媒体基建 (Story 2.1) 阿里云 OSS 雅加达单桶 + 预签名上传 ---
# 真实凭证仅运行环境注入，绝不入库；留空时 L0 单测用 mock，不打真实 OSS。
# 单桶方案：public/private 两桶名都填同一个桶；公开域对象打 public-read ACL，私密域走读签名 URL。
# 后端用此 AccessKey 现签预签名上传 URL（真 key 只在后端，无需 STS/RAM 角色）。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-5.aliyuncs.com
OSS_REGION=ap-southeast-5
OSS_PUBLIC_BUCKET=
OSS_PRIVATE_BUCKET=
OSS_CDN_BASE_URL=
# 对象 key 全局前缀：默认空=生产行为不变。staging 与生产共用同一桶时设为如 `stag/`，
# 让 staging 新上传落到独立命名空间，与生产对象区分（见 docs/runbook-staging.md T1）。
# MEDIA_OSS_KEY_PREFIX=
# SIGNED_URL_TTL_SECONDS=300
# UPLOAD_URL_TTL_SECONDS=600

# --- AI 智能分诊 (Story 4.1) Gemini Developer API ---
# mode=stub（默认）走打桩客户端，无凭证即可启动并验状态机（L0/L1）；
# mode=live 才打真实 gemini-2.5-flash（L2，需真实 key + 私密桶签名 URL）。key 绝不入库 / 不落日志。
GEMINI_MODE=stub
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_TIMEOUT_SECONDS=10

# --- 腾讯 IM 实时会话 (Story 5.5) ---
# mode=stub（默认）走打桩 IM 客户端：本地生成会话 id + 占位 UserSig，无凭证即可验状态机/接单 CAS（L0/L1）。
# mode=live 才接真实腾讯 IM（L2，需真机 + 真实 SDKAppID/SecretKey + SDK 直连）。SecretKey 绝不下发客户端 / 绝不入日志。
IM_MODE=stub
TENCENT_IM_SDK_APP_ID=
TENCENT_IM_SECRET_KEY=
# IM_USERSIG_TTL_SECONDS=86400
# 腾讯 IM 服务端回调签名校验用（/im/callback，内网/白名单 + 签名）。
TENCENT_IM_CALLBACK_TOKEN=
# live REST 域名（数据中心德国/欧洲，与后端同区）+ 管理员 IM 标识（REST 鉴权身份，需控制台配为 App 管理员；不计 MAU）。
# IM_REST_BASE_URL=https://adminapiger.im.qcloud.com
# IM_ADMIN_IDENTIFIER=administrator

# ===== 管理后台（Epic 1）=====
# 首个超级管理员开户（Story 1.1 AdminBootstrap）：仅启动时 env 注入幂等 upsert，绝不入库；建好后可清空。
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
# 后台会话闲置过期（Story 1.2，默认 8h）。
# ADMIN_SESSION_TIMEOUT=8h
# Lark OAuth 登录（Story 1.2，国际版 open.larksuite.com）。redirect-uri 须在 Lark 应用 allowlist 内。
# LARK_BASE_URL=https://open.larksuite.com
LARK_APP_ID=
LARK_APP_SECRET=
LARK_REDIRECT_URI=
# 仅放行该企业租户的 Lark 账号（防个人租户冒用同名邮箱）。
LARK_TENANT_KEY=

# --- 对外 H5 下载 CTA (Story 2.6 名片 /p + P-35 里程碑庆祝分享 /m) ---
# 名片页与里程碑分享页共用的下载按钮目标。留空则用代码默认（已默认指向下方 Play 链接）。
# V1 仅 Android 上架：iOS / 桌面统一兜底到 Play 商店；待 iOS 上架再单独填 CARD_IOS_URL。
# CARD_ANDROID_URL=https://play.google.com/store/apps/details?id=com.tailtopia.app
# CARD_IOS_URL=https://play.google.com/store/apps/details?id=com.tailtopia.app
# CARD_APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=com.tailtopia.app

# --- 内容审核 (内容审核 Story 1) 阿里云内容安全 green20220302 ---
# mode=stub（默认）走打桩客户端，无凭证即可启动并验评分/降级状态机（L0/L1）；
# mode=live 才打真实阿里云内容安全（L2，需真实 AK + 印尼语实测）。AK/Secret 绝不入库/不落日志。
MODERATION_MODE=stub
MODERATION_ALIYUN_REGION=ap-southeast-1
# MODERATION_ALIYUN_ENDPOINT=green-cip.ap-southeast-1.aliyuncs.com
# MODERATION_ALIYUN_AK_ID=       # 留空则复用 ALIYUN_ACCESS_KEY_ID
# MODERATION_ALIYUN_AK_SECRET=   # 留空则复用 ALIYUN_ACCESS_KEY_SECRET
# MODERATION_ALIYUN_TEXT_SERVICE=text_standard  # 文本审核 service 码（国际多语言标准版）
# MODERATION_RISK_THRESHOLD=0.8
# MODERATION_TEXT_TIMEOUT_MS=1000
# MODERATION_IMAGE_TIMEOUT_MS=2000
# MODERATION_IMG_PORN=0.85
# MODERATION_IMG_VIOLENCE=0.80
# MODERATION_IMG_CONTRABAND=0.75
