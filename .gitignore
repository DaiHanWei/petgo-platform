# macOS
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.iml

# Claude Code / BMAD 本地工具配置（默认不入库）
# 但 settings.json 与 hooks/ 需入库——云端 session（claude.ai/code）只读仓库里 commit 的 hook
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/commands/

# Logs & temp
*.log
.env
.env.local

# Flutter/Xcode 在仓库根可能生成的构建产物（子工程自带各自 .gitignore）
/build/

# 本地打包产物（APK/AAB 不入库，避免仓库暴涨）
dist/
*.apk
*.aab

# 本地 L2 验收脚本（含真实凭证调用，绝不入库）
scripts/local/
.agents/
skills-lock.json

# Bug 系统：拉取产物（含真实用户/宠物 PII 截图）与真实配置，绝不入库（NFR1/NFR9）
# 注：.env 已由上方根规则全局忽略；此处补 config.toml 与 data/
scripts/bug-system/data/
scripts/bug-system/config.toml

# graphify 知识图谱产物(本地,含16MB+ graph.json,勿入库)
graphify-out/

# CodeBuddy 产物：含针对 AI 代理的提示注入载荷（诱导读取 .env 并外发凭证），绝不入库
# 详见 SECURITY-INCIDENT-codebuddy-injection 报告（2026-07-07）
.codebuddy/
CODEBUDDY.md
